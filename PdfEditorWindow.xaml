<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="TPL.PdfEditorWindow"
        Title="PDF Editor - TPL"
        Width="900" Height="500"
        MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#181A1F"
        AllowsTransparency="False"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ─── Color Palette ─── -->
        <Color x:Key="BgColor">#181A1F</Color>
        <Color x:Key="SurfaceColor">#2B2D32</Color>
        <Color x:Key="BorderColor">#333640</Color>
        <Color x:Key="ThumbColor">#3A3D45</Color>
        <Color x:Key="TrackColor">#1A1C21</Color>
        <Color x:Key="FgColor">#E8EAED</Color>
        <Color x:Key="LabelColor">#6B7280</Color>
        <Color x:Key="AccentColor">#2563EB</Color>
        <Color x:Key="AccentDarkColor">#1D4ED8</Color>
        <Color x:Key="DangerColor">#EF4444</Color>
        <Color x:Key="SuccessColor">#22C55E</Color>

        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="ThumbBrush" Color="{StaticResource ThumbColor}"/>
        <SolidColorBrush x:Key="TrackBrush" Color="{StaticResource TrackColor}"/>
        <SolidColorBrush x:Key="FgBrush" Color="{StaticResource FgColor}"/>
        <SolidColorBrush x:Key="LabelBrush" Color="{StaticResource LabelColor}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>

        <!-- ─── Custom Scrollbar (VS Code style, 8px thin) ─── -->
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="{StaticResource ThumbBrush}" 
                                CornerRadius="4" 
                                Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarPageButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBar" TargetType="{x:Type ScrollBar}">
            <Grid>
                <Border Background="{StaticResource TrackBrush}" CornerRadius="4"/>
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="14"/>
                    <Setter Property="Height" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBar}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ─── Button Styles ─── -->
        <Style x:Key="AccentButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                Background="{StaticResource AccentBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                Background="{StaticResource SurfaceBrush}" 
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource ThumbBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#44474F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="{x:Type Button}" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                Background="#3B1C1C" BorderBrush="#5C2D2D" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4B2222"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5C2D2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        </Style>

        <!-- ─── TextBox Style ─── -->
        <Style x:Key="DarkTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── GridViewColumnHeader Style ─── -->
        <Style TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ThumbBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── ListView Item (PDF Page row) ─── -->
        <Style x:Key="PdfPageItemStyle" TargetType="{x:Type ListViewItem}">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border x:Name="Bd" Background="{Binding RowBackgroundColorBrush}" 
                                BorderBrush="Transparent" BorderThickness="1.5" 
                                CornerRadius="4" Padding="4,4" Margin="2,1">
                            <GridViewRowPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Selected: gradient border + blended accent/group background -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#60A5FA" Offset="0.0"/>
                                            <GradientStop Color="#C084FC" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="Background" Value="{Binding SelectedBackgroundBrush}"/>
                            </Trigger>
                            <!-- Hover (not selected): brighter group tint -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{Binding HoverBackgroundBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#20FFFFFF"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SourceLabel}" Value="DUMMY">
                    <Setter Property="Height" Value="28"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListViewItem}">
                                <Rectangle Margin="2" RadiusX="4" RadiusY="4" 
                                           Stroke="#60A5FA" StrokeThickness="1.5" StrokeDashArray="4 3" 
                                           Fill="#1560A5FA"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ─── ProgressBar Style ─── -->
        <Style x:Key="SlimProgressBar" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="{StaticResource TrackBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Border CornerRadius="3" Background="{TemplateBinding Background}" ClipToBounds="True">
                            <Border x:Name="PART_Indicator" CornerRadius="3" 
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ─── Main Window Border ─── -->
    <Border Background="{StaticResource BgBrush}" 
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <!-- Title bar -->
                <RowDefinition Height="*"/>
                <!-- Content -->
                <RowDefinition Height="Auto"/>
                <!-- Progress bar -->
                <RowDefinition Height="Auto"/>
                <!-- Bottom bar -->
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR (draggable) ═══ -->
            <Border Grid.Row="0" Background="#12141A" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: App icon + title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Border Width="22" Height="22" CornerRadius="5" Background="{StaticResource AccentBrush}" Margin="0,0,10,0">
                            <TextBlock Text="P" Foreground="White" FontWeight="Bold" FontSize="13" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        </Border>
                        <TextBlock x:Name="txtTitle" Text="PDF Editor — TPL" 
                                   Foreground="{StaticResource FgBrush}" FontSize="13" FontWeight="SemiBold" 
                                   VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    </StackPanel>

                    <!-- Right: Window controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Button x:Name="btnMinimize" Content="─" Width="36" Height="28" 
                            Style="{StaticResource DarkButton}" Padding="0" FontSize="12"
                            Click="BtnMinimize_Click" BorderThickness="0"/>
                        <Button x:Name="btnMaximize" Content="☐" Width="36" Height="28" 
                            Style="{StaticResource DarkButton}" Padding="0" FontSize="14"
                            Click="BtnMaximize_Click" BorderThickness="0" Margin="5,0,0,0"/>
                        <Button x:Name="btnClose" Content="✕" Width="36" Height="28" 
                            Style="{StaticResource DangerButton}" Padding="0" FontSize="11"
                            Click="BtnClose_Click" BorderThickness="0" Margin="5,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ CONTENT ═══ -->
            <Grid Grid.Row="1" Margin="14,10,14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" MinWidth="300"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT PANEL: Toolbar + Page List ─── -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Toolbar -->
                        <RowDefinition Height="*"/>
                        <!-- List -->
                    </Grid.RowDefinitions>

                    <!-- Toolbar: 2 rows, fixed layout -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,6">
                        <!-- Row 1: Plot, Import, Separate PDFs -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Height="56">
                            <Button x:Name="btnPlusPlot" Content="＋ PLOT" 
                                    Style="{StaticResource AccentButton}" FontSize="13" FontWeight="Bold"
                                    Width="80" Height="56" Padding="0" Click="BtnPlusPlot_Click" Margin="0,0,6,0"/>
                            <Button x:Name="btnAdd" Content="Import" 
                                    Style="{StaticResource DarkButton}" FontSize="11" FontWeight="Bold"
                                    Width="100" Height="26" Padding="0" Click="BtnAdd_Click" Margin="0,-30,6,0">
                                <Button.BorderBrush>
                                    <SolidColorBrush Color="{DynamicResource TrackColor}"/>
                                </Button.BorderBrush>
                                <Button.Foreground>
                                    <SolidColorBrush Color="{DynamicResource SuccessColor}"/>
                                </Button.Foreground>
                                <Button.Background>
                                    <SolidColorBrush Color="{DynamicResource BorderColor}"/>
                                </Button.Background>
                            </Button>
                            <CheckBox x:Name="chkSeparatePdfs" Content="Separate PDFs" 
                                      Foreground="{StaticResource LabelBrush}" 
                                      VerticalAlignment="Center" FontSize="11" Margin="0,-28,0,0"/>
                        </StackPanel>
                        <!-- Row 2: Remove, Up, Down, Rotate -->
                        <StackPanel Orientation="Horizontal" Margin="0,-28,0,0">
                            <Button x:Name="btnRemove" Content="Remove" 
                                    Style="{StaticResource DangerButton}" FontSize="11" FontWeight="Bold"
                                    Width="100" Height="26" Padding="0" Click="BtnRemove_Click" Margin="86,-5,6,0"/>
                            <Button x:Name="btnUp" Content="▲" 
                                    Style="{StaticResource DarkButton}" FontSize="11"
                                    Width="34" Height="26" Padding="0" Click="BtnUp_Click" Margin="-1,-5,3,0"/>
                            <Button x:Name="btnDown" Content="▼" 
                                    Style="{StaticResource DarkButton}" FontSize="11"
                                    Width="34" Height="26" Padding="0" Click="BtnDown_Click" Margin="0,-5,0,0"/>
                            <Button x:Name="btnRotate" 
                                    Style="{StaticResource DarkButton}" 
                                    Width="34" Height="26" Padding="0" Click="BtnRotate_Click" Margin="3,-5,0,0" ToolTip="Rotate Clockwise">
                                <Image Source="pack://application:,,,/TPL;component/Resource/IconRotate_32px.png" Width="14" Height="14" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- PDF Page List with STT column -->
                    <ListView x:Name="lstPages" Grid.Row="1"
                              Background="{StaticResource SurfaceBrush}" 
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                              Foreground="{StaticResource FgBrush}"
                              SelectionMode="Extended"
                              AllowDrop="True"
                              SelectionChanged="LstPages_SelectionChanged"
                              PreviewMouseLeftButtonDown="LstPages_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="LstPages_PreviewMouseMove"
                              DragOver="LstPages_DragOver"
                              Drop="LstPages_Drop"
                              ItemContainerStyle="{StaticResource PdfPageItemStyle}"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto" d:ItemsSource="{d:SampleData ItemCount=5}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="#" Width="Auto" 
                                                DisplayMemberBinding="{Binding SequenceNumber}"/>
                                <GridViewColumn Header="" Width="0">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="10" Height="18" CornerRadius="3"
                                                    Background="{Binding GroupColorBrush}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Source" Width="Auto">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="4,1" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}">
                                                        <Setter Property="Background" Value="#1A2563EB"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SourceLabel}" Value="File">
                                                                <Setter Property="Background" Value="#1A22C55E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding SourceLabel}" FontSize="9" 
                                                           FontWeight="SemiBold" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="Foreground" Value="#60A5FA"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SourceLabel}" Value="File">
                                                                    <Setter Property="Foreground" Value="#4ADE80"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Page" Width="Auto" 
                                                DisplayMemberBinding="{Binding DisplayName}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>

                <!-- Separator -->
                <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Center"
                              Background="{StaticResource BorderBrush}"/>

                <!-- ─── RIGHT PANEL: PDF Preview ─── -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" 
                        CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        ClipToBounds="True">
                    <Grid>
                        <WindowsFormsHost x:Name="pdfHost" Margin="0"/>
                        <!-- Placeholder when no page selected -->
                        <TextBlock x:Name="txtNoPreview" Text="Select a page to preview"
                                   Foreground="{StaticResource LabelBrush}" FontSize="14" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Visible"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ PROGRESS BAR (hidden by default) ═══ -->
            <Grid Grid.Row="2" x:Name="pnlProgress" Visibility="Collapsed" Margin="14,8,14,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,4">
                    <TextBlock x:Name="txtProgressLabel" Text="Saving..." 
                               Foreground="{StaticResource FgBrush}" FontSize="11" FontFamily="Segoe UI"
                               DockPanel.Dock="Left"/>
                    <TextBlock x:Name="txtProgressPercent" Text="0%" 
                               Foreground="{StaticResource LabelBrush}" FontSize="11" FontFamily="Segoe UI"
                               DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                </DockPanel>
                <ProgressBar Grid.Row="1" x:Name="progressBar" 
                             Minimum="0" Maximum="100" Value="0"
                             Height="6" Background="{StaticResource TrackBrush}" 
                             Foreground="{StaticResource AccentBrush}" BorderThickness="0">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="{x:Type ProgressBar}">
                            <Border CornerRadius="3" Background="{TemplateBinding Background}" ClipToBounds="True">
                                <Border x:Name="PART_Indicator" CornerRadius="3" 
                                        Background="{TemplateBinding Foreground}"
                                        HorizontalAlignment="Left"/>
                            </Border>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
            </Grid>

            <!-- ═══ BOTTOM BAR ═══ -->
            <Border Grid.Row="3" Background="#12141A" Padding="14,10" CornerRadius="0,0,10,10">
                <DockPanel>
                    <!-- Right side: Save / Cancel -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="btnSave" Content="💾  Save File" 
                                Style="{StaticResource AccentButton}" 
                                Width="140" Height="36" FontSize="13"
                                Click="BtnSave_Click" BorderBrush="#00000000" Margin="0,4,0,0"/>
                        <Button x:Name="btnCancel" Content="Cancel" 
                                Style="{StaticResource DarkButton}" 
                                Width="100" Height="36" Margin="8,4,0,0"
                                Click="BtnCancel_Click"/>
                    </StackPanel>
                    <!-- Left side: File name (fills remaining space) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="File Name" Foreground="{StaticResource LabelBrush}" 
                            FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="txtFileName" Style="{StaticResource DarkTextBox}" 
                            Width="260" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>