<Window x:Class="TPL.MainWindow"
        xmlns:local="clr-namespace:TPL"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TPL" Width="565" Height="505"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="True"
        ResizeMode="NoResize">
    <Window.Resources>
        <Color x:Key="BgColor">#181A1F</Color>
        <Color x:Key="SurfaceColor">#2B2D32</Color>
        <Color x:Key="BorderColor">#333640</Color>
        <Color x:Key="ThumbColor">#3A3D45</Color>
        <Color x:Key="TrackColor">#1A1C21</Color>
        <Color x:Key="FgColor">#E8EAED</Color>
        <Color x:Key="LabelColor">#6B7280</Color>
        <Color x:Key="AccentColor">#2563EB</Color>
        <Color x:Key="AccentDarkColor">#1D4ED8</Color>
        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="ThumbBrush" Color="{StaticResource ThumbColor}"/>
        <SolidColorBrush x:Key="TrackBrush" Color="{StaticResource TrackColor}"/>
        <SolidColorBrush x:Key="FgBrush" Color="{StaticResource FgColor}"/>
        <SolidColorBrush x:Key="LabelBrush" Color="{StaticResource LabelColor}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>

        <!-- Section Header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- AccentButton -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <local:SquircleBorder x:Name="bd" CornerRadius="8" Padding="14,7" Background="{StaticResource AccentBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </local:SquircleBorder>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- DarkButton -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <local:SquircleBorder x:Name="bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </local:SquircleBorder>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ThumbBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- DarkTextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <local:SquircleBorder Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </local:SquircleBorder>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- DarkComboBox -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ThumbBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="ComboBoxToggle" TargetType="ToggleButton">
            <local:SquircleBorder x:Name="bd" CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="24"/>
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="{StaticResource LabelBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </local:SquircleBorder>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource ComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"/>
                            <ContentPresenter IsHitTestVisible="False" Margin="8,0,28,0"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              VerticalAlignment="Center"/>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <local:SquircleBorder Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="10" Padding="0,2,0,0"
                                        >
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </local:SquircleBorder>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- RadioButton / CheckBox dark -->
        <Style x:Key="DarkRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DarkCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Scrollbar 8px -->
        <Style TargetType="ScrollBar">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <local:SquircleBorder Background="{StaticResource TrackBrush}" CornerRadius="4"/>
                                    <Track Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent" BorderThickness="0" Focusable="False">
                                                <RepeatButton.Template>
                                                    <ControlTemplate>
                                                        <Rectangle Fill="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate>
                                                        <local:SquircleBorder Background="{StaticResource ThumbBrush}" CornerRadius="4" Margin="1"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent" BorderThickness="0" Focusable="False">
                                                <RepeatButton.Template>
                                                    <ControlTemplate>
                                                        <Rectangle Fill="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <local:SquircleBorder CornerRadius="14" Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <local:SquircleBorder Grid.Row="0" Background="#12141A" TopLeftRadius="14" TopRightRadius="14" BottomLeftRadius="0" BottomRightRadius="0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Height="40">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <local:SquircleBorder Width="20" Height="20" CornerRadius="6" Background="{StaticResource AccentBrush}" Margin="0,0,8,0">
                            <TextBlock Text="P" Foreground="White" FontWeight="Bold" FontSize="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        </local:SquircleBorder>
                        <TextBlock x:Name="txtTitle" Text="Batch Plot PDF — TPL"
                                   Foreground="{StaticResource FgBrush}" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
                        <Button Content="✕" Width="32" Height="26" Style="{StaticResource DarkButton}" Padding="0"
                                Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </local:SquircleBorder>

            <!-- CONTENT -->
            <Grid Grid.Row="1" Margin="14,8,14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN -->
                <StackPanel Grid.Column="0">
                    <!-- Section 1: Printer -->
                    <TextBlock Text="1. PRINTER — PAPER SIZE — STYLE" Style="{StaticResource SectionHeader}" FontSize="12"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Printer:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cbPrinters" Grid.Row="0" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="CbPrinters_SelectionChanged"/>
                        <TextBlock Grid.Row="1" Text="Paper Size:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cbPapers" Grid.Row="1" Grid.Column="1" Style="{StaticResource DarkComboBox}"/>
                        <TextBlock Grid.Row="2" Text="Plot Style:" Style="{StaticResource FieldLabel}"/>
                        <DockPanel Grid.Row="2" Grid.Column="1">
                            <Button x:Name="btnEditStyle" DockPanel.Dock="Right" Width="28" Height="28"
                                    Style="{StaticResource DarkButton}" Padding="4" Margin="4,0,0,0"
                                    Click="BtnEditStyle_Click" ToolTip="Edit Plot Style">
                                <Image Width="16" Height="16" Source="pack://application:,,,/TPL;component/Resource/StyleSettings_32px.ico" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <ComboBox x:Name="cbStyles" Style="{StaticResource DarkComboBox}"/>
                        </DockPanel>
                    </Grid>

                    <!-- Section 2: Frame -->
                    <TextBlock Text="2. PLOT FRAMES" Style="{StaticResource SectionHeader}" Margin="0,6,0,6" FontSize="12"/>
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>
                        <RadioButton x:Name="rbBlockMode" Grid.Row="0" Content="Block:" IsChecked="True"
                                     Style="{StaticResource DarkRadio}" FontWeight="Bold"
                                     Checked="ModeChanged" Unchecked="ModeChanged"/>
                        <TextBox x:Name="txtBlocks" Grid.Row="0" Grid.Column="1" Style="{StaticResource DarkTextBox}"
                                 IsReadOnly="True" Height="26"/>
                        <Button x:Name="btnSelectBlock" Grid.Row="0" Grid.Column="2" Content="Select" Height="26"
                                Style="{StaticResource DarkButton}" Margin="4,0,0,0" Click="BtnSelectBlock_Click" Foreground="#FFE8EAED"/>

                        <RadioButton x:Name="rbLayerMode" Grid.Row="1" Content="Layer:"
                                     Style="{StaticResource DarkRadio}" FontWeight="Bold"
                                     Checked="ModeChanged" Unchecked="ModeChanged"/>
                        <TextBox x:Name="txtLayers" Grid.Row="1" Grid.Column="1" Style="{StaticResource DarkTextBox}"
                                 IsReadOnly="True" Height="26"/>
                        <Button x:Name="btnSelectLayer" Grid.Row="1" Grid.Column="2" Content="Select" Height="26"
                                Style="{StaticResource DarkButton}" Margin="4,0,0,0" Click="BtnSelectLayer_Click"/>
                    </Grid>

                    <!-- Section 3: Output -->
                    <TextBlock Text="3. OUTPUT" Style="{StaticResource SectionHeader}" Margin="0,8,0,6" FontSize="12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="File Name:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtFileName" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                 Style="{StaticResource DarkTextBox}" Height="26"/>
                        <TextBlock Grid.Row="1" Text="Folder:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtPath" Grid.Row="1" Grid.Column="1" Style="{StaticResource DarkTextBox}" Height="26"/>
                        <Button x:Name="btnBrowsePath" Grid.Row="1" Grid.Column="2" Content="Browse" Height="26"
                                Style="{StaticResource DarkButton}" Margin="4,0,0,0" Click="BtnBrowsePath_Click"/>
                    </Grid>

                    <!-- Options Grid -->
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- PDF Options -->

                        <!-- Image Options -->
                        <Grid Grid.Column="0" VerticalAlignment="Center" Height="82">
                            <CheckBox x:Name="chkMergePdf" Content="Merge PDF" IsChecked="True"
                 Style="{StaticResource DarkCheck}" Foreground="#22C55E" FontWeight="Bold" Margin="0,0,0,57"
                 />
                            <CheckBox x:Name="chkPdfEditor" Content="PDF Editor"
                 Style="{StaticResource DarkCheck}" Foreground="#C084FC" FontWeight="Bold"
                 Checked="ChkPdfEditor_Changed" Unchecked="ChkPdfEditor_Changed" Margin="0,27,0,30"/>
                            <CheckBox x:Name="chkOpenPdf" Content="Open when done" IsChecked="True"
                 Style="{StaticResource DarkCheck}" 
                 Checked="ChkMergePdf_Changed" Unchecked="ChkMergePdf_Changed" Margin="0,52,0,5"/>
                        </Grid>

                        <!-- Image Options -->
                        <local:SquircleBorder Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="10,8"
								BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="15,0,0,0" Height="80" VerticalAlignment="Top">
                            <StackPanel>
                                <!-- Row 1: Checkbox -->
                                <CheckBox x:Name="chkConvertImage" Content="Convert to Image"
										  Style="{StaticResource DarkCheck}" Foreground="#60A5FA" FontWeight="Bold" Margin="0,0,0,4"
										  Checked="ChkConvertImage_Changed" Unchecked="ChkConvertImage_Changed" HorizontalAlignment="Center"/>
                                <StackPanel x:Name="pnlImgFormat" Orientation="Vertical">
                                    <StackPanel Orientation="Horizontal" Width="99" RenderTransformOrigin="0.615,0.502">
                                        <RadioButton x:Name="rbPng" Content="PNG" HorizontalAlignment="Left" Style="{StaticResource DarkRadio}" Margin="0,0,16,0" />
                                        <RadioButton x:Name="rbJpg" Content="JPG" Style="{StaticResource DarkRadio}" IsChecked="True" Width="39" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="DPI:" Style="{StaticResource FieldLabel}" Margin="0,0,8,0" Width="30" />
                                        <TextBox x:Name="txtDpi" Text="600" VerticalAlignment="Top" Style="{StaticResource DarkTextBox}" Width="55" Height="22           " TextAlignment="Center" FontSize="11" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </local:SquircleBorder>
                    </Grid>
                </StackPanel>

                <!-- RIGHT COLUMN -->
                <StackPanel Grid.Column="2">
                    <!-- Section 4: Scope -->
                    <TextBlock Text="4. SCOPE" Style="{StaticResource SectionHeader}" FontSize="12" />
                    <local:SquircleBorder Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10,6">
                        <StackPanel>
                            <RadioButton x:Name="rbAll" GroupName="Scope" Content="All Layouts" Style="{StaticResource DarkRadio}" Checked="TriggerPreview" />
                            <RadioButton x:Name="rbCurrent" GroupName="Scope" Content="Current Layout" IsChecked="True" Style="{StaticResource DarkRadio}" Checked="TriggerPreview" />
                            <DockPanel>
                                <Button x:Name="btnSelectManual" DockPanel.Dock="Right" Content="Select" Height="25" 
                                        Style="{StaticResource DarkButton}" Click="BtnSelectManual_Click" Margin="0,0,0,0" Width="50" />
                                <RadioButton x:Name="rbSelect" GroupName="Scope" Content="Manual Select" Style="{StaticResource DarkRadio}" Checked="TriggerPreview" />
                            </DockPanel>
                        </StackPanel>
                    </local:SquircleBorder>

                    <!-- Section 5: Sort -->
                    <TextBlock Text="5. SORT ORDER" Style="{StaticResource SectionHeader}" Margin="0,10,0,6" FontSize="12"/>
                    <local:SquircleBorder Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Priority 1:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cbOrd1" Grid.Row="0" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="TriggerPreviewCombo"/>
                            <TextBlock Grid.Row="1" Text="Priority 2:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cbOrd2" Grid.Row="1" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="TriggerPreviewCombo"/>
                            <TextBlock Grid.Row="2" Text="Base Point:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cbBase" Grid.Row="2" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="TriggerPreviewCombo"/>
                            <TextBlock Grid.Row="3" Text="Tolerance:" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtFuzz" Grid.Row="3" Grid.Column="1" Text="100"
                                     Style="{StaticResource DarkTextBox}" Height="26" LostFocus="TriggerPreviewText"/>
                            <CheckBox x:Name="chkMark" Grid.Row="4" Content="Mark plot regions"
                                      Style="{StaticResource DarkCheck}" Checked="TriggerPreviewCheck" Unchecked="TriggerPreviewCheck" HorizontalAlignment="Left" Margin="0,3,0,3" Width="121" Grid.ColumnSpan="2"/>
                            <Button x:Name="btnDeleteMarks" Grid.Row="4" Grid.Column="1" Content="Delete"
                                    Style="{StaticResource DarkButton}" HorizontalAlignment="Right" Height="25"
                                    Click="BtnDeleteMarks_Click">
                                <Button.Background>
                                    <SolidColorBrush Color="{StaticResource BgColor}"/>
                                </Button.Background>
                            </Button>
                        </Grid>
                    </local:SquircleBorder>

                    <!-- Section 6: Orientation -->
                    <TextBlock Text="6. ORIENTATION" Style="{StaticResource SectionHeader}" Margin="0,10,0,6" FontSize="12"/>
                    <local:SquircleBorder Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10,6">
                        <StackPanel Orientation="Horizontal" Height="20">
                            <RadioButton x:Name="rbOrientAuto" GroupName="Orientation" Content="Auto" IsChecked="True" Style="{StaticResource DarkRadio}" Margin="0,0,10,0" FontSize="11" />
                            <RadioButton x:Name="rbOrientPortrait" GroupName="Orientation" Content="Portrait" Style="{StaticResource DarkRadio}" Margin="0,0,10,0" FontSize="11" />
                            <RadioButton x:Name="rbOrientLandscape" GroupName="Orientation" Content="Landscape" Style="{StaticResource DarkRadio}" FontSize="11" />
                        </StackPanel>
                    </local:SquircleBorder>
                </StackPanel>
            </Grid>

            <!-- BOTTOM BAR -->
            <local:SquircleBorder Grid.Row="2" Background="#12141A" Padding="14,8" TopLeftRadius="0" TopRightRadius="0" BottomLeftRadius="14" BottomRightRadius="14" Height="50">
                <DockPanel>
                    <TextBlock x:Name="lblCount" Text="Ready" DockPanel.Dock="Left"
                               Foreground="{StaticResource LabelBrush}" FontFamily="Segoe UI"
                               FontSize="11" FontStyle="Italic" VerticalAlignment="Center" Width="200"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnBackToEditor" Content="Editor" Visibility="Collapsed"
                                Style="{StaticResource DarkButton}" Width="90" Height="36" Margin="0,0,6,0"
                                Click="BtnBackToEditor_Click"/>
                        <Button x:Name="btnPlot" Content="▶  START PLOT"
                                Style="{StaticResource AccentButton}" Width="120" Height="36" FontSize="13"
                                Click="BtnPlot_Click" Margin="0,-2,0,0"/>
                        <Button x:Name="btnCancel" Content="Cancel"
                                Style="{StaticResource DarkButton}" Width="90" Height="36" Margin="6,-2,0,0"
                                Click="BtnCancel_Click"/>
                    </StackPanel>
                </DockPanel>
            </local:SquircleBorder>
        </Grid>
    </local:SquircleBorder>
</Window>
