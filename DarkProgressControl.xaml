<UserControl x:Class="TPL.DarkProgressControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="400">
    <UserControl.Resources>
        <!-- ─── ProgressBar Gradient Brush ─── -->
        <LinearGradientBrush x:Key="ProgressGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2563EB" Offset="0.0"/>
            <GradientStop Color="#C084FC" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- ─── ProgressBar Style ─── -->
        <Style x:Key="DarkProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Background" Value="#1A1C21"/>
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#333640"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" 
                                ClipToBounds="True">
                            <Grid>
                                <!-- PART_Track: WPF dùng ActualWidth của nó để tính Width cho PART_Indicator -->
                                <Border x:Name="PART_Track"/>
                                <!-- PART_Indicator: Thanh tiến trình thực tế -->
                                <Rectangle x:Name="PART_Indicator" RadiusX="5" RadiusY="5" Margin="1" HorizontalAlignment="Left">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#2563EB" Offset="0.0"/>
                                            <GradientStop Color="#C084FC" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock x:Name="txtProgressLabel" Text="Saving..." 
                       Foreground="#E8EAED" FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"
                       DockPanel.Dock="Left"/>
            <TextBlock x:Name="txtProgressPercent" Text="0%" 
                       Foreground="#2563EB" FontSize="12" FontFamily="Segoe UI" FontWeight="Bold"
                       DockPanel.Dock="Right" HorizontalAlignment="Right"/>
        </DockPanel>
        <ProgressBar Grid.Row="1" x:Name="progressBar" Style="{StaticResource DarkProgressBarStyle}"
                     Minimum="0" Maximum="100" Value="0" />
    </Grid>
</UserControl>
